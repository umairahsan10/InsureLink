{
  "info": {
    "name": "InsureLink Phase 2 APIs - Claims Module",
    "description": "Complete test collection for Claims Core Module with JWT authentication.\n\nWorkflow:\n1. Login as Hospital user to submit claims\n2. Login as Insurer user to approve/reject claims\n\nClaim Status Flow:\nPending → Approved/Rejected/OnHold → Paid (terminal)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "claim_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "claim_number",
      "value": "",
      "type": "string"
    },
    {
      "key": "document_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "hospital_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "insurer_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "corporate_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "plan_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "visit_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "employee_number",
      "value": "",
      "type": "string"
    },
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "Login as different users to test role-based access.\n\nHospitals can: Submit claims, view their claims\nInsurers can: Approve/Reject claims, view all claims",
      "item": [
        {
          "name": "Login Hospital User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', jsonData.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
                  "    console.log('✅ Hospital token saved! Use this for submitting claims.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hospital@test.com\",\n  \"password\": \"Hospital123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Insurer User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', jsonData.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
                  "    console.log('✅ Insurer token saved! Use this for approving/rejecting claims.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"insurer@test.com\",\n  \"password\": \"Insurer123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Hospital Visits",
      "description": "Hospital visit management for claims workflow.\n\nHospitals search for employee visits to create claims.",
      "item": [
        {
          "name": "Get Unclaimed Visits by Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.visits && jsonData.data.visits.length > 0) {",
                  "        pm.collectionVariables.set('visit_id', jsonData.data.visits[0].id);",
                  "        console.log('✅ Employee found:', jsonData.data.employee.employeeNumber);",
                  "        console.log('✅ Unclaimed visits:', jsonData.data.visits.length);",
                  "        console.log('✅ Using visit_id:', jsonData.data.visits[0].id);",
                  "    } else {",
                  "        console.log('⚠️ No unclaimed visits found for this employee');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/hospitals/visits/unclaimed?employeeNumber={{employee_number}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "hospitals", "visits", "unclaimed"],
              "query": [
                {
                  "key": "employeeNumber",
                  "value": "{{employee_number}}"
                }
              ]
            },
            "description": "Get unclaimed hospital visits for an employee at the logged-in hospital.\\n\\nRequires Hospital role. Only returns visits at the hospital's own location with status 'Pending'.\\n\\nResponse includes:\\n- Employee details (id, name, corporate, plan, insurer)\\n- List of unclaimed visits (id, visitDate, dischargeDate, dependent info)\\n\\nUse the visit_id in the Submit Claim request."
          }
        }
      ]
    },
    {
      "name": "Claims - CRUD",
      "description": "Basic CRUD operations for claims.\n\nHospitals submit claims.\nInsurers view and process claims.",
      "item": [
        {
          "name": "Submit Claim (Hospital)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('claim_id', jsonData.data.id);",
                  "    pm.collectionVariables.set('claim_number', jsonData.data.claimNumber);",
                  "    console.log('✅ Claim created:', jsonData.data.claimNumber);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalVisitId\": \"{{visit_id}}\",\n  \"amountClaimed\": 125000.50,\n  \"treatmentCategory\": \"Inpatient Surgery\",\n  \"priority\": \"Normal\",\n  \"notes\": \"Laparoscopic appendectomy - patient admitted for 3 days post-operation monitoring\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims"]
            },
            "description": "Submit a new claim. Requires Hospital role.\\n\\nThe corporateId, planId, and insurerId are auto-populated from the hospital visit's employee data.\\n\\nRequired fields:\\n- hospitalVisitId (UUID) - from /v1/hospitals/visits/unclaimed endpoint\\n- amountClaimed (number with 2 decimals)\\n\\nOptional fields:\\n- treatmentCategory (string)\\n- priority (Low, Normal, High)\\n- notes (string)\\n\\nNote: The visit status will be updated to 'Claimed' after submission."
          }
        },
        {
          "name": "Get All Claims",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/claims?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "Pending",
                  "disabled": true
                },
                {
                  "key": "hospitalId",
                  "value": "{{hospital_id}}",
                  "disabled": true
                },
                {
                  "key": "insurerId",
                  "value": "{{insurer_id}}",
                  "disabled": true
                },
                {
                  "key": "claimType",
                  "value": "Inpatient",
                  "disabled": true
                },
                {
                  "key": "minAmount",
                  "value": "10000",
                  "disabled": true
                },
                {
                  "key": "maxAmount",
                  "value": "500000",
                  "disabled": true
                },
                {
                  "key": "fromDate",
                  "value": "2024-01-01",
                  "disabled": true
                },
                {
                  "key": "toDate",
                  "value": "2024-12-31",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "disabled": true
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "disabled": true
                }
              ]
            },
            "description": "Get paginated list of claims with optional filters.\n\nHospitals see only their claims.\nInsurers see claims for their policies."
          }
        },
        {
          "name": "Get Claim by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}"]
            },
            "description": "Get detailed claim information including patient, hospital, and plan details."
          }
        },
        {
          "name": "Update Claim (Hospital)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountClaimed\": 150000.75,\n  \"treatmentCategory\": \"Inpatient Surgery - Extended Care\",\n  \"priority\": \"High\",\n  \"notes\": \"Updated: Additional post-op care required due to minor complications\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}"]
            },
            "description": "Update claim details. Only allowed while claim is in Pending status.\n\nUpdatable fields:\n- amountClaimed\n- treatmentCategory\n- priority\n- notes"
          }
        },
        {
          "name": "Delete Claim (Hospital)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}"]
            },
            "description": "Soft delete a claim. Only allowed for Pending claims by the submitting hospital."
          }
        }
      ]
    },
    {
      "name": "Claims - Workflow",
      "description": "Claim status workflow operations.\n\nInsurers approve/reject/hold claims.\nStatus flow: Pending → Approved/Rejected/OnHold → Paid",
      "item": [
        {
          "name": "Approve Claim (PATCH)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvedAmount\": 120000,\n  \"eventNote\": \"Claim approved. Standard deductible of 5000 applied.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}", "approve"]
            },
            "description": "Approve a pending claim. Requires Insurer role.\n\napprovedAmount must be ≤ amountClaimed.\n\nReturns minimal claim data (id, claimNumber, status, amounts) for fast response."
          }
        },
        {
          "name": "Reject Claim (PATCH)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventNote\": \"Claim rejected: Pre-existing condition exclusion applies as per policy terms section 4.2.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}", "reject"]
            },
            "description": "Reject a pending claim. Requires Insurer role and rejection reason.\n\nReturns minimal claim data for fast response."
          }
        },
        {
          "name": "Put Claim On Hold",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventNote\": \"Additional documentation required: Please provide itemized hospital bill and discharge summary.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/on-hold",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}", "on-hold"]
            },
            "description": "Put a claim on hold pending additional information. Requires Insurer role.\n\nReturns minimal claim data for fast response."
          }
        },
        {
          "name": "Mark Claim as Paid",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentReference\": \"TXN-2024-0115-789456\",\n  \"eventNote\": \"Payment processed via IBFT to hospital account.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/paid",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "{{claim_id}}", "paid"]
            },
            "description": "Mark an approved claim as paid. Terminal state. Requires Insurer role.\n\nReturns minimal claim data for fast response."
          }
        },
        {
          "name": "Bulk Approve Claims",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ Bulk approve results:');",
                  "    console.log('  Successful:', jsonData.data.successful.length);",
                  "    console.log('  Failed:', jsonData.data.failed.length);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"claimIds\": [\"claim-id-1\", \"claim-id-2\", \"claim-id-3\"],\n  \"notes\": \"Batch approval for verified claims.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/bulk-approve",
              "host": ["{{base_url}}"],
              "path": ["v1", "claims", "bulk-approve"]
            },
            "description": "Approve multiple claims at once. Returns list of successful and failed operations."
          }
        }
      ]
    },
    {
      "name": "Claims - Events",
