    {
      "name": "Claims - CRUD",
      "item": [
        {
          "name": "Submit Claim (Hospital)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('claim_id', jsonData.data.id);",
                  "    pm.collectionVariables.set('claim_number', jsonData.data.claimNumber);",
                  "    console.log('✅ Claim created:', jsonData.data.claimNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalVisitId\": \"{{visit_id}}\",\n  \"corporateId\": \"{{corporate_id}}\",\n  \"planId\": \"{{plan_id}}\",\n  \"insurerId\": \"{{insurer_id}}\",\n  \"amountClaimed\": 125000.50,\n  \"treatmentCategory\": \"Inpatient Surgery\",\n  \"priority\": \"Normal\",\n  \"notes\": \"Laparoscopic appendectomy - patient admitted for 3 days post-operation monitoring\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims"
              ]
            },
            "description": "Submit a new claim. Requires Hospital role.\n\nRequired fields:\n- hospitalVisitId (UUID)\n- corporateId (UUID)\n- planId (UUID)\n- insurerId (UUID)\n- amountClaimed (number with 2 decimals)\n\nOptional fields:\n- treatmentCategory (string)\n- priority (Low, Normal, High)\n- notes (string)"
          },
          "response": []
        },
        {
