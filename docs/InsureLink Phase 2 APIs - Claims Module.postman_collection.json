          "response": []
        },
        {
          "name": "Mark Claim as Paid",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentReference\": \"TXN-2024-0115-789456\",\n  \"paidAmount\": 120000,\n  \"paymentMethod\": \"BankTransfer\",\n  \"notes\": \"Payment processed via IBFT to hospital account.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/paid",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims",
                "{{claim_id}}",
                "paid"
              ]
            },
            "description": "Mark an approved claim as paid. Terminal state. Requires Insurer role."
          },
          "response": []
        },
        {
          "name": "Bulk Approve Claims",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('✅ Bulk approve results:');",
                  "    console.log('  Successful:', jsonData.data.successful.length);",
                  "    console.log('  Failed:', jsonData.data.failed.length);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"claimIds\": [\"claim-id-1\", \"claim-id-2\", \"claim-id-3\"],\n  \"notes\": \"Batch approval for verified claims.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/bulk-approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims",
                "bulk-approve"
              ]
            },
            "description": "Approve multiple claims at once. Returns list of successful and failed operations."
          },
          "response": []
        }
      ],
      "description": "Claim status workflow operations.\n\nInsurers approve/reject/hold claims.\nStatus flow: Pending → Approved/Rejected/OnHold → Paid"
    },
