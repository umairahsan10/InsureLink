            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Additional documentation required: Please provide itemized hospital bill and discharge summary.\",\n  \"requiredDocuments\": [\"Itemized Bill\", \"Discharge Summary\", \"Lab Reports\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/on-hold",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims",
                "{{claim_id}}",
                "on-hold"
              ]
            },
            "description": "Put a claim on hold pending additional information. Requires Insurer role."
