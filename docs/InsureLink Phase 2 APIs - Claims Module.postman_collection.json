    {
      "name": "Claims - Workflow",
      "item": [
        {
          "name": "Approve Claim (PATCH)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvedAmount\": 45000,\n  \"eventNote\": \"Claim approved. Standard deductible of 5000 applied.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims",
                "{{claim_id}}",
                "approve"
              ]
            },
            "description": "Approve a pending claim. Requires Insurer role.\n\napprovedAmount must be ≤ billedAmount."
          },
          "response": []
        },
        {
          "name": "Reject Claim (PATCH)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventNote\": \"Claim rejected: Pre-existing condition exclusion applies as per policy terms section 4.2.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/claims/{{claim_id}}/reject",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "claims",
                "{{claim_id}}",
                "reject"
              ]
            },
            "description": "Reject a pending claim. Requires Insurer role and rejection reason."
          },
          "response": []
        },
        {
          "name": "Put Claim On Hold",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
