# =========================================================================
# InsureLink Server - Environment Configuration Template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =========================================================================

# -------------------------------------------------------------------------
# Supabase (Public - exposed to client through Next.js)
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------------
# Supabase Storage (Backend - server-only, never expose to client)
# Get the service role key from: Supabase Dashboard > Settings > API
# -------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET_NAME='Insurelink'

# -------------------------------------------------------------------------
# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# -------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# -------------------------------------------------------------------------
# JWT Configuration
# Generate strong secrets (>= 64 chars random). Example:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -------------------------------------------------------------------------
JWT_SECRET="replace-with-long-random-secret"
JWT_EXPIRES_IN="45m"
JWT_REFRESH_SECRET="replace-with-different-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# -------------------------------------------------------------------------
# Server Port
# Local development default. On Render this is set automatically via PORT.
# -------------------------------------------------------------------------
PORT=3001

# -------------------------------------------------------------------------
# CORS - set to your frontend URL in production
# e.g. CORS_ORIGIN=https://your-frontend.vercel.app
# -------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000
